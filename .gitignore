# Node / Frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
frontend/dist/
dist/
build/

# Python / Backend
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# Environment / secrets — CRITICAL
# Aggressively exclude ALL .env* variants at any depth.
# If you later want .env.example tracked as a template, use:
#   git add -f 04_environment/.env.example
.env
.env.*
**/.env
**/.env.*
*.pem
*.key

# Logs
logs/
*.log

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Claude workspace
.claude/

# Database dumps
*.sql.gz
*.dump
*.backup

# Temp
tmp/
.tmp/

# Old dist backups (rollback artifacts, not source)
dist.old*
**/dist.old*

# Timestamped backup files (*.bak, *.bak.<timestamp>, etc.)
*.bak
*.bak.*
**/*.bak
**/*.bak.*
