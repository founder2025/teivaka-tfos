# FILE: 04_environment/.env.example
#
# Teivaka Agricultural TOS — Environment Variable Reference
# Platform: Teivaka Agri-TOS, Fiji
# Backend: Python 3.12 + FastAPI 0.115+
#
# Copy this file to .env and fill in all values before running.
# NEVER commit the actual .env file to version control.
# All secrets in production must be rotated from these defaults.
#
# Sections:
#   1. Database
#   2. Redis & Celery
#   3. Application Security
#   4. Storage (Supabase)
#   5. Communications (Meta WhatsApp Cloud API)
#   6. AI Services (Anthropic Claude + OpenAI Whisper)
#   7. Deployment (Hetzner + Caddy)
#   8. TIS Configuration
#   9. Operational Limits
#   10. Monitoring
#   11. Payments (Stripe)
#   12. Farm-Specific Constants

# ==============================================================================
# 1. DATABASE
# ==============================================================================

# Primary PostgreSQL connection URL (async driver for FastAPI)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# For Docker Compose, host is the service name 'db'
# For production: use a connection pooler like PgBouncer between app and db
DATABASE_URL=postgresql+asyncpg://teivaka:password@db:5432/teivaka_db

# PostgreSQL database name (also used by Docker entrypoint)
# Must match the dbname in DATABASE_URL
POSTGRES_DB=teivaka_db

# PostgreSQL user (must have CREATE SCHEMA, CREATE TABLE privileges)
# This user owns the teivaka_db database
POSTGRES_USER=teivaka

# PostgreSQL password — CHANGE IN PRODUCTION to a strong random string
# Minimum 32 characters, mixed case + numbers + symbols
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change-in-production

# ==============================================================================
# 2. REDIS & CELERY
# ==============================================================================

# Redis URL for Celery broker (queue 0)
# Redis database 0 is used for Celery task queue messages
# Docker Compose service name is 'redis'
REDIS_URL=redis://redis:6379/0

# Celery broker URL (should point to Redis)
# Used by Celery workers and beat scheduler to receive tasks
# Redis database 1 is used to separate broker from cache
CELERY_BROKER_URL=redis://redis:6379/1

# Celery result backend (stores task return values and status)
# Redis database 2 is separate from broker to avoid key collisions
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ==============================================================================
# 3. APPLICATION SECURITY
# ==============================================================================

# Secret key for JWT signing — MUST be changed in production
# Generate with: openssl rand -hex 32
# This key signs all JWT access and refresh tokens — if compromised, all sessions are compromised
SECRET_KEY=your-256-bit-secret-key-here-change-in-production

# JWT signing algorithm
# HS256 = HMAC with SHA-256 (symmetric — same key signs and verifies)
# Acceptable for single-service JWT; use RS256 if multiple services need to verify
ALGORITHM=HS256

# Access token expiry in minutes
# Set to 24 hours (1440 min) — field workers at F001/F002 may be offline
# for extended periods; short expiry would log them out mid-task in the field.
# PWA handles silent refresh automatically when connectivity returns.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Refresh token expiry in days
# Longer-lived token used to get new access tokens
# Stored securely (HTTP-only cookie or secure storage)
# 30 days — aligns with field rotation cycles at remote sites (esp. F002 Kadavu)
REFRESH_TOKEN_EXPIRE_DAYS=30

# Allowed CORS origins (comma-separated)
# Include both local dev and production domains
# No trailing slashes
CORS_ORIGINS=http://localhost:3000,https://app.teivaka.com

# ==============================================================================
# 4. STORAGE (SUPABASE)
# ==============================================================================

# Supabase project URL
# Found in: Supabase Dashboard > Settings > API > Project URL
# Used for Supabase Storage (voice audio files, farm photos)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public key — safe for client-side use)
# Found in: Supabase Dashboard > Settings > API > anon public
# Used for Storage operations from the backend service
# Use service_role key instead if you need RLS bypass on storage
SUPABASE_KEY=your-supabase-anon-key

# Supabase Storage bucket name
# This bucket must be created in Supabase Dashboard before running
# Contains: voice-logs/, farm-photos/, documents/
# Set bucket to private — all access through signed URLs
SUPABASE_BUCKET_NAME=teivaka-farm-data

# ==============================================================================
# 5. COMMUNICATIONS (META WHATSAPP CLOUD API — no Twilio)
# ==============================================================================
# No Twilio account needed. Use your existing Fiji number (Vodafone/Digicel).
#
# Setup steps:
#   1. Go to: developers.facebook.com → Create App → Business → Add WhatsApp
#   2. Add your Fiji mobile number as the WhatsApp Business number
#   3. Copy Phone Number ID (NOT the number itself) → META_PHONE_NUMBER_ID
#   4. Generate a Permanent System User Token → META_WHATSAPP_TOKEN
#   5. Register this webhook URL in Meta dashboard:
#        https://yourdomain.com/api/v1/webhooks/whatsapp
#   6. For dev testing without Meta approval: leave token blank → mock mode (console log)

# Permanent access token from Meta System User
# Found in: Meta Business Manager → System Users → Generate Token
# Permissions required: whatsapp_business_messaging, whatsapp_business_management
META_WHATSAPP_TOKEN=

# Phone Number ID from Meta WhatsApp dashboard
# Found in: developers.facebook.com → Your App → WhatsApp → API Setup
# This is a numeric ID (e.g. 123456789012345) — NOT the actual phone number
META_PHONE_NUMBER_ID=

# Your Fiji WhatsApp Business number in E.164 format
# e.g. +6799XXXXXX (Vodafone FJ) or +6798XXXXXX (Digicel FJ)
WHATSAPP_BUSINESS_NUMBER=+679

# Verification token — you choose this string, then enter it in Meta dashboard
# Used for one-time webhook URL verification
META_WHATSAPP_VERIFY_TOKEN=teivaka-webhook-verify

# Cody's personal WhatsApp number (E.164 format) — injected into OpenClaw system prompt
# as {CODY_WHATSAPP_NUMBER}. Only this number can authorize sensitive TFOS actions.
# Never hardcode this in system_prompt.md — change it here if the number rotates.
CODY_WHATSAPP_NUMBER=+679

# ==============================================================================
# 6. AI SERVICES
# ==============================================================================

# Anthropic API key for Claude API
# Found in: https://console.anthropic.com/ > API Keys
# Format: sk-ant-api03-...
# Used for: TIS Knowledge Broker, TIS Operational Interpreter, weekly AI insights
# NEVER commit this key — treat as a production credential
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for all TIS calls
# Current production model for Teivaka: claude-sonnet-4-20250514
# Update this to change model across all TIS modules simultaneously
# Check Anthropic model availability before changing
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API key
# Used for: Whisper API (voice transcription) + text-embedding-3-small (KB embeddings)
# Found in: https://platform.openai.com/api-keys
# Format: sk-...
# Note: This is a separate API key from the Anthropic key above
OPENAI_API_KEY=sk-...

# OpenAI embedding model for Knowledge Base RAG
# text-embedding-3-small: 1536 dimensions, cost $0.02/1M tokens
# Produces vectors stored in shared.kb_articles.embedding_vector
# IMPORTANT: if you change this model, regenerate ALL kb_articles embeddings
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI Whisper model for voice transcription
# whisper-1 is the current production model
# Cost: ~$0.006/minute of audio
WHISPER_MODEL=whisper-1

# ==============================================================================
# 7. DEPLOYMENT (HETZNER + CADDY)
# ==============================================================================

# Hetzner server IP address
# Used for: SSH access reference, internal network configuration
# CAX21 VPS: 8GB RAM, 4 vCPU ARM64, located in EU (Helsinki or Nuremberg)
HETZNER_SERVER_IP=your-server-ip

# Primary application domain
# The frontend PWA domain — Caddy serves this
# DNS A record must point to HETZNER_SERVER_IP
DOMAIN=app.teivaka.com

# API subdomain
# The FastAPI backend domain — Caddy proxies to FastAPI on port 8000
# DNS A record must point to HETZNER_SERVER_IP
API_DOMAIN=api.teivaka.com

# Email for Let's Encrypt TLS certificate registration
# Caddy uses this for ACME certificate requests
# Must be a valid email — Let's Encrypt sends expiry notifications here
CADDY_EMAIL=cody@teivaka.com

# ── Transactional email (verification + password reset) ──────────────────────
# Resend is the live path — DigitalOcean blocks outbound SMTP ports, so the code
# dispatches over Resend's HTTPS API whenever a Resend key is present. It needs
# ONLY the API key; SMTP_HOST is optional. If neither is set, verification mail
# is silently skipped (logged, not sent) — which strands signups. Always set
# SMTP_PASSWORD to the Resend key in production.
SMTP_PASSWORD=re_your_resend_api_key      # Resend API key (re_...) — REQUIRED for email
SMTP_FROM=noreply@teivaka.com             # from-address on a Resend-verified domain
SMTP_HOST=                                # optional; leave blank to use the Resend HTTPS API
SMTP_PORT=587
SMTP_USER=
# FRONTEND_URL must be the public site so verification links resolve correctly
FRONTEND_URL=https://teivaka.com

# ── Google sign-in (OAuth via Google Identity Services) ──────────────────────
# OAuth *Web application* client ID from Google Cloud Console → Credentials.
# Authorized JavaScript origins must include https://teivaka.com. Empty => the
# "Continue with Google" button stays a disabled "coming soon" placeholder.
# Backend verifies the Google token's audience against GOOGLE_CLIENT_ID; the
# frontend build reads VITE_GOOGLE_CLIENT_ID (set both to the same value).
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Application environment
# Values: development | staging | production
# Controls: debug mode, error detail in responses, CORS strictness
# Set to 'production' on Hetzner server
ENVIRONMENT=development

# ==============================================================================
# 8. TIS CONFIGURATION
# ==============================================================================

# Maximum tokens per TIS Claude API call (combined input + output budget)
# Actual per-module limits: Knowledge Broker = 600 output, Interpreter = 800 output
# This is the overall safety cap — prevents runaway token usage
TIS_MAX_TOKENS_PER_CALL=1000

# Daily TIS query limit for FREE tier users
# Counter stored in Redis, resets at midnight Pacific/Fiji time
# Increase this to improve free tier experience (costs ~FJD 0.40/extra call)
TIS_DAILY_LIMIT_FREE=5

# Daily TIS query limit for BASIC tier users
# PREMIUM and CUSTOM tiers have no effective limit (set to 999999 in code)
TIS_DAILY_LIMIT_BASIC=20

# Minimum vector similarity score for Knowledge Broker to use a KB article (Layer 1)
# Cosine similarity range: 0.0 (no similarity) to 1.0 (identical)
# 0.65 = article must be at least 65% semantically similar to query
# Below this threshold, TIS falls back to Fiji Agricultural Intelligence (Layer 2)
# Lower this to use KB articles more aggressively; raise to require tighter match
# Start at 0.65; tune after 30 days of real usage data from kb_article_candidates
VECTOR_SIMILARITY_THRESHOLD=0.65

# Path to the Fiji Agricultural Intelligence context document
# Injected into every Knowledge Broker system prompt as the base knowledge layer
# This file ensures TIS answers are grounded in Fiji conditions from Day 1
# Update this file as market prices change, pests emerge, or chemicals change
FIJI_INTELLIGENCE_PATH=09_knowledge_base/FIJI_FARM_INTELLIGENCE.md

# Enable knowledge layer logging for monitoring and tuning
# Logs every KB decision (VALIDATED_KB vs FIJI_INTELLIGENCE) to ai_commands table
# Set to true in production for the first 90 days; can disable after tuning
TIS_KNOWLEDGE_LAYER_LOGGING=true

# Target KB coverage percentage (for monitoring dashboard)
# Percentage of TIS KB queries answered from validated KB articles (Layer 1)
# Day 1 target: 0% (expected — no published articles yet)
# 30-day target: 20% (first batch of articles validated)
# 90-day target: 60% (core 6 active crop articles fully validated)
# Long-term target: 80%+ (most common questions hit validated protocols)
# This is a monitoring reference only — no code uses this value
TIS_KB_COVERAGE_TARGET=60

# Default timezone for the platform
# All Fiji operations run on Pacific/Fiji (UTC+12)
# Used for: daily limit resets, report generation, timestamp display
TENANT_DEFAULT_TIMEZONE=Pacific/Fiji

# ==============================================================================
# 9. OPERATIONAL LIMITS
# ==============================================================================

# Maximum file upload size in megabytes
# Applies to: farm photos, document uploads
# Voice audio is separately capped by MAX_AUDIO_DURATION_SECONDS
MAX_UPLOAD_SIZE_MB=10

# Maximum voice recording duration in seconds
# Whisper is billed per second — limit prevents accidental long recordings
# 60 seconds is more than enough for any farm command
# A typical command is 5-15 seconds
MAX_AUDIO_DURATION_SECONDS=60

# Maximum outbound WhatsApp messages per hour (per tenant)
# Meta Cloud API has per-phone-number throughput limits — this prevents bursting past them
# 80/hour = 1.3 messages/minute — sufficient for typical farm usage
WHATSAPP_RATE_LIMIT_PER_HOUR=80

# Maximum offline queue size (number of operations stored locally in PWA)
# Used by the PWA service worker for offline operation
# Operations are synced when connectivity is restored
MAX_OFFLINE_QUEUE_SIZE=500

# Sync batch size for offline sync
# How many queued operations to send per sync batch
# Smaller batches reduce risk of timeout on slow connections (Kadavu)
SYNC_BATCH_SIZE=50

# PgBouncer connection pool size (for Phase 2 connection pooling)
# CAX21 has enough RAM for 20 persistent connections
# PostgreSQL max_connections should be set to at least this + 5 for admin
PGBOUNCER_POOL_SIZE=20

# ==============================================================================
# 10. MONITORING & LOGGING
# ==============================================================================

# Application log level
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use INFO in production (DEBUG generates too much output)
# Use DEBUG locally for development
LOG_LEVEL=INFO

# Sentry DSN for error monitoring
# Get from: https://sentry.io > Project > Settings > Client Keys (DSN)
# Leave empty to disable Sentry (not recommended for production)
# Sentry captures unhandled exceptions and performance issues
SENTRY_DSN=https://xxx@sentry.io/xxx

# Destination for TFOS CRITICAL infra alerts from ops.run_health_checks
# (single email or distribution list). Fired after 3 consecutive FAILs on
# any ops.health_checks row. Only NEW var required by the monitoring task;
# Resend credential is reused from SMTP_PASSWORD, bridge secret is reused
# from TIS_BRIDGE_TOKEN (see /etc/systemd/system/tis-bridge.service).
MONITORING_ALERT_EMAIL=founder@teivaka.com

# Backup failure alert recipient. Must be a real, monitored mailbox.
# Read by scripts/teivaka_backup.sh send_alert() via Resend HTTPS API.
# Hardcoded recipient was the V7-original false-pass root cause (Strike
# #122 V7-redux, 2026-05-09). See B96 (phantom-recipient audit) for
# verification doctrine.
ALERT_RECIPIENT=founder@teivaka.com

# ==============================================================================
# 11. PAYMENTS (STRIPE)
# ==============================================================================

# Stripe secret key
# Used for: subscription management, payment processing
# Production: starts with sk_live_
# Test/dev: starts with sk_test_
# NEVER expose this key — it allows full Stripe account access
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret
# Used to verify that webhook events come from Stripe (not spoofed)
# Found in: Stripe Dashboard > Webhooks > Signing secret
# Format: whsec_...
# Each webhook endpoint has its own signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ==============================================================================
# 12. ALERT ESCALATION
# ==============================================================================

# Days before a MEDIUM severity alert is escalated to HIGH
# If a medium alert remains open for this many days, its severity increases
# Prevents low-priority issues from being ignored indefinitely
ALERT_ESCALATION_MEDIUM_DAYS=3

# Days before a HIGH severity alert is escalated to CRITICAL
# If a high alert remains open this long without resolution, escalate
# CRITICAL alerts trigger immediate WhatsApp notification to farm manager
ALERT_ESCALATION_HIGH_DAYS=7

# ==============================================================================
# 13. FARM-SPECIFIC CONSTANTS
# ==============================================================================

# F002 (Viyasiyasi Farm, Kadavu Island) ferry buffer in days
# All input and supply orders for F002 must be placed at least this many days
# in advance of the required delivery date
# Kadavu ferry schedule is irregular — 7 days is the safe minimum buffer
# CRITICAL: automation rules for F002 use this value for reorder alerts
F002_FERRY_BUFFER_DAYS=7

# Profit share default rate for F001 (Save-A-Lot, Korovou Serua)
# Set to null — must be configured manually in tenant_subscriptions
# This is a business-sensitive figure specific to Cody's arrangement
# Do not set a default — always set explicitly in production
PROFIT_SHARE_DEFAULT_RATE=null

# Kava inactivity alert threshold in days
# CRP-KAV (Kava) is a 4-year crop with expected periods of low activity
# If no events are logged for a kava PU for this many days, trigger an alert
# 180 days = 6 months — shorter interval would generate false alerts for kava
# Kava requires minimal maintenance input compared to vegetable crops
KAVA_INACTIVITY_ALERT_DAYS=180
